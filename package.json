{
  "name": "pytheory",
  "version": "1.0.0",
  "main": "dist/extension.js",
  "engines": {
    "node": ">=24.14.1"
  },
  "type": "module",
  "scripts": {
    "build": "tsc --noEmit && tsx build.ts --production",
    "build:dev": "tsc --noEmit && tsx build.ts",
    "start": "npm run build:dev && extensions-cli run --storage-directory .dev/storage --temp-directory .dev/tmp",
    "package": "npm run build && extensions-cli package -i dist/pyodide -i dist/pytheory -i dist/python-worker.mjs"
  },
  "dependencies": {
    "@ableton-extensions/sdk": "file:vendor/ableton-extensions-sdk-1.0.0-beta.0.tgz",
    "abcjs": "^6.6.3",
    "pyodide": "^314.0.0"
  },
  "devDependencies": {
    "@ableton-extensions/cli": "file:vendor/ableton-extensions-cli-1.0.0-beta.0.tgz",
    "@types/node": "^24.1.0",
    "esbuild": "0.28.0",
    "tsx": "^4.19.0",
    "typescript": "^5.9.3"
  },
  "allowScripts": {
    "esbuild@0.28.0": true
  }
}
